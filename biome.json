{
	"$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
	"files": {
		"includes": [
			"**",
			"!node_modules",
			"!dist",
			"!build",
			"!coverage",
			"!profiles",
			"!postcss.config.cjs"
		]
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"a11y": {
				"noSvgWithoutTitle": "off",
				"noLabelWithoutControl": "off"
			},
			"style": {
				"noNonNullAssertion": "off"
			},
			"suspicious": {
				"noControlCharactersInRegex": "off",
				"noAssignInExpressions": "off"
			},
			"complexity": {
				"noBannedTypes": "off"
			}
		}
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
